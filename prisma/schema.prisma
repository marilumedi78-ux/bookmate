generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?  // hashed password for credentials auth
  name          String?
  avatarUrl     String?
  plan          String   @default("free") // free, plus, pro
  isVip         Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  lsCustomerId     String? // Lemon Squeezy customer ID
  lsSubscriptionId String? // Current Lemon Squeezy subscription ID
  lsVariantId      String? // Current Lemon Squeezy variant ID
  streakDays    Int      @default(0)
  lastReadDate  String?  // YYYY-MM-DD
  totalReadMin  Int      @default(0)
  iaHoursUsed   Float    @default(0) // hours of IA voice used this month
  explicaUsed   Int      @default(0) // number of "Explica" uses this month
  ocrUsed       Int      @default(0) // number of OCR scans this month
  audiobookHoursUsed Float @default(0) // hours of downloadable MP3 generated this month (Pro plan quota)
  usageMonth    String?  // YYYY-MM format, tracks which month the usage counters are for
  // Reading goals
  dailyGoalMin  Int      @default(20) // daily reading goal in minutes
  weeklyGoalDays Int     @default(5)  // weekly goal: how many days to read

  // ─── Referral system ───
  // Each user gets a unique referral code they can share with friends.
  // When a friend signs up using the code and later upgrades to a paid plan
  // (Plus or Pro), BOTH users get 1 month of Pro free.
  referralCode        String?  @unique  // e.g. "MARILU" or "MARILU-7K3X"
  referredById        String?  // the user who referred this one (User.id)
  referralCredits     Int      @default(0)  // months of Pro earned via referrals
  referralCount       Int      @default(0)  // how many people signed up with this user's code
  referralPaidCount   Int      @default(0)  // how many of those converted to paid (Pro/Plus)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  books         Book[]
  achievements  Achievement[]
  highlights    Highlight[]
  readingLogs   ReadingLog[]
  audiobooks    Audiobook[]
  referredBy    User?    @relation("Referrals", fields: [referredById], references: [id])
  referralsMade User[]   @relation("Referrals")
}

model Book {
  id             String    @id @default(cuid())
  userId         String
  title          String
  author         String?
  fileName       String
  filePath       String
  fileHash       String?   // SHA-256 hash for duplicate detection
  coverColor     String    @default("#4DB6AC") // generated cover color
  totalPages     Int       @default(0)
  currentPage    Int       @default(0)
  currentCharIdx Int       @default(0) // character index for TTS position
  totalChars     Int       @default(0)
  readChars      Int       @default(0)
  estimatedMin   Int       @default(0) // estimated reading time in minutes
  isFinished     Boolean   @default(false)
  language       String    @default("es")
  textContent    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  highlights     Highlight[]
  readingLogs    ReadingLog[]
  summary        BookSummary?
  emotions       BookEmotion?
  audiobooks     Audiobook[]

  @@map("books")
}

// AI-generated book summary: 3 key points + 5 quotes + "who is this for"
model BookSummary {
  id            String   @id @default(cuid())
  bookId        String   @unique
  keyPoints     String   // JSON array of 3 strings
  quotes        String   // JSON array of 5 strings
  targetReader  String   // "Para quien es este libro"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  book          Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("book_summaries")
}

// Emotion graph per chapter: array of {charStart, charEnd, emotion, intensity, label}
model BookEmotion {
  id        String   @id @default(cuid())
  bookId    String   @unique
  data      String   // JSON array of emotion points
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("book_emotions")
}

model Highlight {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  text      String
  note      String?
  color     String   @default("#FBBF24") // yellow, pink, green, blue
  charStart Int
  charEnd   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("highlights")
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "first_book", "10_books", "100_hours", "streak_7", etc.
  unlockedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("achievements")
}

model ReadingLog {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  minutes   Int      @default(0)
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("reading_logs")
}

model VipEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  addedBy   String?
  createdAt DateTime @default(now())

  @@map("vip_emails")
}

// Generated audiobook MP3 — created when a Pro user downloads a book as MP3
// with a premium voice. The MP3 bytes live in Vercel Blob / S3 (keyed by
// contentHash); this row tracks ownership + metadata + cuota usage.
model Audiobook {
  id            String   @id @default(cuid())
  userId        String
  bookId        String

  // Voice used to generate the audio (e.g. "lucia-es-ES", "diego-es-AR")
  voiceId       String

  // SHA-256 of (book.textContent + voiceId) — used for cross-user cache.
  // Two users downloading the same book + same voice → same contentHash →
  // we only generate the MP3 once and serve it to both.
  contentHash   String

  // Storage key (Vercel Blob / S3 object key)
  storageKey    String

  // Audio metadata
  durationSec   Int      @default(0)   // total seconds of audio
  sizeBytes     Int      @default(0)   // MP3 file size

  // Generation status: pending → ready → failed
  status        String   @default("pending")
  errorMessage  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book          Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, voiceId])           // one audiobook per book+voice
  @@index([contentHash])                // fast cache lookup
  @@map("audiobooks")
}
